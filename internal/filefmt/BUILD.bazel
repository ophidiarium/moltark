go_test(
    name = "filefmt_test",
    srcs = [
        "gitattributes_test.go",
        "json_test.go",
        "paths_test.go",
        "toml_test.go",
        "yaml_test.go",
    ],
    embed = [":filefmt"],
    deps = [
        "//internal/model",
        "@com_github_burntsushi_toml//:toml",
    ],
)
