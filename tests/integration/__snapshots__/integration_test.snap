/-/-/-/
== Moltarkfile ==
core = use("moltark/core")
python = use("moltark/python")

repo = core.project(
    id = "repo",
    kind = "workspace",
    path = ".",
)

python.python_project(
    id = "backend",
    parent = repo,
    name = "backend",
    path = "backend",
    version = "0.1.0",
    requires_python = ">=3.12",
)

== backend/pyproject.toml ==
[project]
name = "backend"
version = "0.1.0"
requires-python = ">=3.12"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.moltark]
schema-version = 1
template-version = "python/v2"

== .gitattributes ==
# BEGIN Moltark managed
.moltark/** linguist-generated=true
# END Moltark managed

